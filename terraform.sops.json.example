  "_comment": "SOPS-encrypted env-specific config. Copy to terraform.sops.json, fill real values, then: sops --encrypt --in-place terraform.sops.json. See docs/SOPS_SETUP.md.",
  "network_prefix": "192.168.0",
  "domain": "example.com",
  "vm_ssh_public_key_path": "~/.ssh/id_ed25519.pub",
