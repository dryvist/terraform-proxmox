  "proxmox_ssh_username": "root",
  "rack_servers": {
    "node-a": {
      "chassis": "r410",
      "bmc_ip": "192.168.8.10",
      "bmc_mac": "00:00:00:00:00:00",
      "service_tag": "EXAMPLE1",
      "mgmt_ip": "192.168.5.11"
    },
    "node-b": {
      "chassis": "r710",
      "bmc_ip": "192.168.8.20",
      "bmc_mac": "00:00:00:00:00:00",
      "service_tag": "EXAMPLE2",
      "mgmt_ip": "192.168.5.21"
    }
  }
}
