# AWS credentials and config
.aws/
aws-credentials
*.aws

# Environment files
.env
.env.*
!.env.example

# Doppler configuration (contains project/config names)
.doppler.yaml
SECRETS_SETUP.md

# SOPS age private keys (never commit)
*.age
keys.txt

# SOPS plaintext/decrypted files (NEVER commit - these contain unencrypted secrets)
secrets.plain.yaml
secrets.dec.yaml

# Note: SOPS-encrypted files ARE safe to commit (values are ciphertext):
#   secrets.enc.yaml     - SOPS-encrypted YAML (committed when used)
#   terraform.sops.json  - SOPS-encrypted JSON (committed after: sops --encrypt --in-place)

# Environment-specific documentation (contains sensitive setup info)
docs/DOPPLER.md
docs/secrets-management.md

# IDE files
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# OS specific files
*.log
*.tmp
*.temp
.cache/

# Backup files
*.bak
*.backup
*.orig

# Local development files
local/
temp/
tmp/
.local/
.docs/

# Local context files with sensitive data (never commit)
# Note: Real infrastructure context is maintained in private int_homelab repo
*_LOCAL.md
*.local.*

# Ansible files
.ansible/
ansible/inventory/hosts.yml
ansible/.molecule/
ansible/roles/*/.molecule/
*.retry

# Timing script results (don't commit execution measurements)
scripts/timing-results.txt

# direnv cache (nix-direnv)
.direnv/

# ai-workflows runtime checkout (checked out by CI into .ai-workflows/ at runtime)
.ai-workflows/

# Claude Code repo-scoped MCP server config. NOT committed because it
# auto-executes on agent load — committing would silently spawn the listed
# MCP servers (terraform-mcp-server, bunx-fetched AWS tools, etc.) for every
# contributor without review or version pinning. Contributors who want MCP
# tooling in this repo should create their own .mcp.json locally.
.mcp.json

# Live deployment config — contains real node names, VM inventory, and ZFS pool names.
# Private desired-state input — lives in the on-prem `s3` store, fetched by terragrunt
# (see agentsmd/rules/infra/deployment-json-source-of-truth.md). Repo keeps only the example.
deployment.json

# ---------------------------------------------------------------------
# dryvist org-default: secrets, credentials & AI-assistant local state
# Source of truth: dryvist/.github -> configs/gitignore (PR #43).
# Carve-outs intentionally absent (committed by convention): .envrc,
# *.sops.*, .terraform.lock.hcl
# ---------------------------------------------------------------------

# Environment files (committed examples kept via negation)
.env.local
.env.*.local
!.env.*.example

# Private keys & certificates
*.ppk
id_rsa
id_ed25519

# Ansible Vault
*.vault
vault.yml
vault.yaml
.vault_pass
.vault_password
.vault-pass*
.vault-password*

# Generic secret material
secrets.yml
secrets.yaml
*.secrets.yml
*.secrets.yaml
secrets.dec.yaml
*credentials*

# Cloud provider credentials
.azure/
gcloud-credentials.json
kubeconfig
*.kubeconfig

# Doppler secrets fallback cache (encrypted snapshot of the WHOLE config) + setup
doppler.json
.doppler/

# Terraform / OpenTofu state & tfvars are secret-bearing
**/.terraform/*
*.tfplan
!*.tfvars.example

